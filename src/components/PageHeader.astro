---
interface Props {
  eyebrow: string;
  title: string;
  lede?: string;
}

const { eyebrow, title, lede } = Astro.props;
const heroBase = '/images/path-hero-b';
---

<header class="relative isolate overflow-hidden min-h-[58vh] lg:min-h-[64vh] flex items-end">
  <picture class="absolute inset-0 block h-full w-full">
    <source srcset={`${heroBase}.webp`} type="image/webp" />
    <img
      src={`${heroBase}.jpg`}
      alt=""
      aria-hidden="true"
      class="absolute inset-0 h-full w-full object-cover"
      loading="eager"
      decoding="async"
      fetchpriority="high"
      width="2000"
      height="1126"
    />
  </picture>
  <div class="absolute inset-0 bg-gradient-to-t from-black/61 via-black/26 to-transparent" aria-hidden="true"></div>
  <div class="container-prose relative z-10 pt-32 pb-14 lg:pt-40 lg:pb-20 text-ivory">
    <p class="eyebrow !text-ivory/90"><span class="rule mr-3 !bg-ivory/80"></span>{eyebrow}</p>
    <h1 class="mt-6 max-w-4xl text-ivory [text-shadow:0_2px_18px_rgba(0,0,0,0.55)]" set:html={title} />
    {
      lede && (
        <p class="mt-8 max-w-2xl text-lg font-serif italic text-ivory/95 [text-shadow:0_1px_12px_rgba(0,0,0,0.6)]">
          {lede}
        </p>
      )
    }
  </div>
</header>
