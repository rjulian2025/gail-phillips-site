---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found — Gail A. Phillips, LCSW" noindex>
  <section class="py-32">
    <div class="container-prose text-center">
      <h1 class="font-serif text-6xl text-primary">404</h1>
      <p class="mt-4 text-muted-foreground">The page you're looking for doesn't exist or has been moved.</p>
      <a href="/" class="btn-quiet mt-10">Go home</a>
    </div>
  </section>
</BaseLayout>

