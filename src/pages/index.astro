---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroBackground from '../components/HeroBackground.astro';

const title = 'Gail A. Phillips, LCSW — Psychodynamic Psychotherapy';
const description =
  'Deep psychodynamic psychotherapy for adults ready to change at the root. Buckhead, Atlanta and virtual sessions across Georgia and Florida.';
const heroPreload = '/images/gail-garden-hero-1280.webp';
---

<BaseLayout title={title} description={description} canonicalPath="/" preloadImage={heroPreload}>
  <section class="relative lg:min-h-[88vh] overflow-hidden lg:flex lg:items-center">
    <HeroBackground />
    <div class="relative container-wide bg-sage-deep lg:bg-transparent pt-12 pb-16 lg:pt-28 lg:pb-32 w-full">
      <div class="max-w-xl lg:max-w-[34rem]">
        <p class="eyebrow lg:[text-shadow:0_1px_8px_rgba(0,0,0,0.5)]"><span class="rule mr-3"></span>Buckhead · Atlanta · Virtual in GA & FL</p>
        <h1 class="mt-7 font-serif text-ivory lg:[text-shadow:0_2px_18px_rgba(0,0,0,0.55)]">
          Deep work.<br />
          Lasting change.<br />
          <em class="text-gold not-italic font-light">Let's begin.</em>
        </h1>
        <p class="mt-8 text-lg text-ivory/95 font-serif italic leading-relaxed lg:[text-shadow:0_1px_10px_rgba(0,0,0,0.6)]">
          Psychodynamic psychotherapy for adults ready to understand why they feel the way they feel — and change it at the root.
        </p>
        <div class="mt-10 flex flex-wrap gap-6 items-center">
          <a href="/begin" class="btn-quiet !bg-ivory !text-sage-deep !border-ivory hover:!bg-transparent hover:!text-ivory">
            Schedule a complimentary consultation
          </a>
          <a href="/the-work" class="btn-ghost !text-ivory !border-ivory">The Work →</a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-28 lg:py-36">
    <div class="container-wide">
      <div class="grid lg:grid-cols-3 gap-14 lg:gap-20">
        {
          [
            {
              k: '01',
              title: 'Relief that lasts',
              body: 'Strategies help — but without deeper work, old patterns return. We tend to the root, not only the symptom.'
            },
            {
              k: '02',
              title: 'A discreet, sacred space',
              body: 'A Buckhead home office with a private entrance for clients who value their privacy and virtual telehealth sessions for your convenience.'
            },
            {
              k: '03',
              title: 'Someone who has done the work',
              body: 'Thirty-four years of clinical experience, rooted from the beginning in modern psychodynamic practice.'
            }
          ].map((p) => (
            <article>
              <p class="eyebrow">{p.k}</p>
              <h2 class="mt-4 font-serif text-primary text-3xl">{p.title}</h2>
              <p class="mt-5 text-muted-foreground leading-relaxed">{p.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-linen py-28 lg:py-36">
    <div class="container-wide grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      <img
        src="/images/gail-office.webp"
        alt="Gail A. Phillips' Buckhead consulting room — two upholstered chairs and a leather sofa under warm lamplight"
        class="w-full aspect-[4/3] object-cover shadow-2xl"
        loading="lazy"
        decoding="async"
        width="1600"
        height="1200"
        sizes="(max-width: 1024px) 100vw, 50vw"
      />
      <div>
        <p class="eyebrow"><span class="rule mr-3"></span>Who this is for</p>
        <h2 class="mt-6 font-serif">
          For the person who has tried everything — and knows something deeper needs to shift.
        </h2>
        <p class="mt-7 text-muted-foreground leading-relaxed">
          You may be a thoughtful adult who has read the books, done the coaching, tried the apps. Something still pulls at you. A relational pattern. An old grief. A sense of not being able to keep carrying this alone.
        </p>
        <p class="mt-5 text-muted-foreground leading-relaxed">
          This work is unhurried, relational, and rigorous. It asks more of you — and offers more in return.
        </p>
        <a href="/who-i-work-with" class="btn-ghost mt-10">See who I work with →</a>
      </div>
    </div>
  </section>

  <section class="py-28 lg:py-36 px-6 lg:px-12 text-center">
    <blockquote class="mx-auto max-w-3xl lg:max-w-4xl m-0">
      <p class="font-serif italic text-3xl lg:text-4xl text-primary leading-snug">
        "My goal is to help you begin feeling better immediately — and to do the deeper work that means you won't end up back where you started."
      </p>
      <footer class="eyebrow mt-10 block">— Gail A. Phillips, LCSW</footer>
    </blockquote>
  </section>
</BaseLayout>

