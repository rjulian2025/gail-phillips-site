---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { articles, articlesBySlug, articleSlugs } from '../../data/articles';
import { site } from '../../data/site';

export function getStaticPaths() {
  return articleSlugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const article = articlesBySlug[slug!];

if (!article) {
  return Astro.redirect('/resources');
}

const canonicalPath = `/resources/${article.slug}`;
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.title,
  description: article.lede,
  author: {
    '@type': 'Person',
    name: site.name,
    jobTitle: 'Licensed Clinical Social Worker',
    url: `${site.url}/about`
  },
  publisher: { '@type': 'Person', name: site.name },
  datePublished: article.publishedAt,
  dateModified: article.publishedAt,
  inLanguage: 'en-US',
  articleSection: article.bucket,
  keywords: article.keywords.join(', '),
  mainEntityOfPage: { '@type': 'WebPage', '@id': `${site.url}${canonicalPath}` }
};
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: article.faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a }
  }))
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Resources', item: `${site.url}/resources` },
    { '@type': 'ListItem', position: 2, name: article.title, item: `${site.url}${canonicalPath}` }
  ]
};
---

<BaseLayout
  title={article.metaTitle}
  description={article.metaDescription}
  canonicalPath={canonicalPath}
  ogType="article"
  schema={[articleSchema, faqSchema, breadcrumbSchema]}
>
  <Fragment slot="head">
    <meta name="keywords" content={article.keywords.join(', ')} />
  </Fragment>

  <PageHeader eyebrow={article.bucket} title={article.title} lede={article.lede} />

  <article class="py-20 lg:py-28">
    <div class="container-prose">
      <div class="flex items-center gap-3 text-sm text-muted-foreground">
        <span>{article.readMinutes} min read</span>
        <span aria-hidden="true">·</span>
        <span>By Gail A. Phillips, LCSW</span>
      </div>

      <div class="mt-12 space-y-12 text-lg leading-relaxed text-ink/85">
        {article.sections.map((section) => (
          <section>
            <h2 class="font-serif text-3xl text-primary">{section.heading}</h2>
            <div class="mt-5 space-y-5">
              {section.body.map((paragraph) => (
                <p>{paragraph}</p>
              ))}
            </div>
          </section>
        ))}
      </div>

      <section class="mt-20 pt-12 border-t border-border">
        <p class="eyebrow"><span class="rule mr-3"></span>Common questions</p>
        <h2 class="mt-4 font-serif text-3xl text-primary">Questions people ask</h2>
        <dl class="mt-10 space-y-8">
          {article.faqs.map((faq) => (
            <div>
              <dt class="font-serif text-xl text-ink">{faq.q}</dt>
              <dd class="mt-3 text-muted-foreground leading-relaxed">{faq.a}</dd>
            </div>
          ))}
        </dl>
      </section>

      <section class="mt-20 pt-12 border-t border-border bg-linen -mx-6 px-6 py-12 lg:-mx-12 lg:px-12">
        <p class="font-serif italic text-2xl text-primary">If something here meets you where you are —</p>
        <p class="mt-4 text-muted-foreground leading-relaxed">
          A complimentary consultation is a quiet conversation, no commitment. We will talk about what brings you, and whether this practice is the right fit.
        </p>
        <a href="/begin" class="btn-quiet mt-8">Schedule a complimentary consultation</a>
      </section>

      {
        article.related.length > 0 && (
          <section class="mt-20 pt-12 border-t border-border">
            <p class="eyebrow">Related reading</p>
            <ul class="mt-6 space-y-4">
              {article.related.map((relatedSlug) => {
                const related = articlesBySlug[relatedSlug];
                if (!related) return null;
                return (
                  <li>
                    <a href={`/resources/${related.slug}`} class="font-serif italic text-xl text-primary hover:text-sage transition-colors">
                      — {related.title}
                    </a>
                  </li>
                );
              })}
            </ul>
          </section>
        )
      }

      <div class="mt-16 pt-8 border-t border-border text-sm text-muted-foreground">
        <a href="/resources" class="hover:text-primary transition-colors">← Back to Resources</a>
      </div>
    </div>
  </article>
</BaseLayout>

